<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Vyapar Drishti Sales Invoice - Motors Edition</title>
    <style>
        * {
            box-sizing: border-box !important;
        }

        body {
            padding: 0 !important;
            margin: 0 !important;
            font-family: Arial, sans-serif !important;
            font-size: 11px;
            color: #000000;
            background-color: #ffffff;
        }

        @media print {
            body {
                margin: 0 !important;
                padding: 0 !important;
            }

            .no-print {
                display: none !important;
            }
        }

        .invoice-container {
            width: 190mm !important;
            margin: 0mm auto !important;
            background-color: #ffffff;
        }

        table.items-table {
            width: 100% !important;
            border-collapse: collapse !important;
            font-size: 9px !important;
            page-break-inside: auto;
            table-layout: fixed !important;
        }

        .items-table tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        .items-table th,
        .items-table td {
            border: 1px solid #000000 !important;
            padding: 4px 3px !important;
            font-weight: normal !important;
        }

        .totals-section {
            page-break-inside: avoid;
        }
    </style>
</head>

<body>
    <div class="invoice-container">
    {# ---------------- HEADER SECTION ---------------- #}
    {% macro invoice_header() %}
    <table style="width: 190mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border: 1px solid #000000 !important;
            border-bottom: none !important;
            height: 80mm !important;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <!-- Top GSTIN and Title -->
        <tr>
            <td style="padding: 2mm !important; background-color: #ffffff;">
                <table style="width: 100% !important; border-collapse: collapse;" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="width: 33% !important; text-align: left; font-size: 10px; font-weight: normal; color: #000;">
                            GSTIN : {{ company.tin }}
                        </td>
                        <td style="width: 34% !important; text-align: center !important; font-size: 12px; color: #000; text-decoration: underline;">
                            TAX INVOICE
                        </td>
                        <td style="width: 33% !important; text-align: right !important; font-size: 10px; font-style: italic; color: #000;">
                            Original Copy
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- Company Header Row -->
        <tr>
            <td style="padding: 1mm 2mm 3mm 2mm !important; text-align: center;">
                <div style="font-size: 18px; font-weight: normal; color: #000000; margin-bottom: 0.5mm; letter-spacing: 0.5px;">
                    {{ company.company_name }}
                </div>
                <div style="font-size: 10px; color: #000000; line-height: 1.3;">
                    {{ company.address_1 }}, {{ company.address_2 }}<br>
                    Tel. : {{ company.phone.code }} {{ company.phone.number }} {% if company.email %}&nbsp;&nbsp;&nbsp;Email : {{ company.email }}{% endif %}
                </div>
            </td>
        </tr>
        
        <!-- Party and Invoice Details Block -->
        <tr style="border-top: 1px solid #000000 !important; border-bottom: 1px solid #000000 !important;">
            <td style="padding: 0 !important;">
                <table style="width: 100% !important; border-collapse: collapse;" cellpadding="0" cellspacing="0">
                    <tr>
                        <!-- Left: Party Details -->
                        <td style="width: 50% !important; padding: 2mm !important; vertical-align: top !important; border-right: 1px solid #000000 !important; font-size: 10px; line-height: 1.35;">
                            <div style="font-style: italic; margin-bottom: 1mm;">Party Details :</div>
                            <div style="font-weight: normal;">{{ party.name | upper }}</div>
                            <div>{{ party.mailing_address | upper }}</div>
                            <div>{% if party.mailing_city %}{{ party.mailing_city | upper }}, {% endif %}{{ party.mailing_state | upper }}, {{ party.mailing_pincode }}</div>
                            <div style="margin-top: 3mm;">
                                GSTIN / UIN &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;: {{ party.tin }}
                            </div>
                        </td>
                        <!-- Right: Invoice Details -->
                        <td style="width: 50% !important; padding: 2mm !important; vertical-align: top !important; font-size: 10px; line-height: 1.35;">
                            <table style="width: 100%; border-collapse: collapse;" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="width: 35%;">Invoice No.</td>
                                    <td>: {{ invoice.voucher_number }}</td>
                                </tr>
                                <tr>
                                    <td>Dated</td>
                                    <td>: {{ invoice.date }}</td>
                                </tr>
                                <tr>
                                    <td>Place of Supply</td>
                                    <td>: {{ invoice.place_of_supply }}{% if party.mailing_state_code %} ({{ party.mailing_state_code }}){% endif %}</td>
                                </tr>
                                <tr>
                                    <td>Reverse Charge</td>
                                    <td>: {{ invoice.is_reversed_charge or 'N' }}</td>
                                </tr>
                                <tr>
                                    <td>Station</td>
                                    <td>: </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}

    {# ---------------- ITEMS TABLE ---------------- #}
    {% macro items_table(items, offset=0) %}
    <table style="width: 190mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-left: 1px solid #000000 !important;
            border-right: 1px solid #000000 !important;
            border-bottom: none !important;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="padding: 0mm !important;">
                <table class="items-table" style="width: 100% !important; border-collapse: collapse !important;" cellpadding="3" cellspacing="0">
                    <thead>
                        <tr style="font-size: 9px; text-align: center;">
                            <th style="width: 4%;">S.N.</th>
                            <th style="width: 25%; text-align: left;">Description of Goods</th>
                            <th style="width: 8%;">Item<br>Alias</th>
                            <th style="width: 9%;">HSN/SAC<br>Code</th>
                            <th style="width: 6%;">Qty.</th>
                            <th style="width: 6%;">Unit</th>
                            <th style="width: 7%;">MRP /<br>Net</th>
                            <th style="width: 6%;">CGST<br>Rate</th>
                            <th style="width: 7%;">CGST<br>Amount</th>
                            <th style="width: 6%;">SGST<br>Rate</th>
                            <th style="width: 7%;">SGST<br>Amount</th>
                            <th style="width: 9%;">Amount (₹)</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                        <tr style="font-size: 9px; vertical-align: top; border-bottom: none !important;">
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ offset + loop.index }}.</td>
                            <td style="text-align: left; border-bottom: none !important; border-top: none !important;">{{ item.name }}</td>
                            <td style="text-align: left; border-bottom: none !important; border-top: none !important;">{{ item.item_id or '' }}</td>
                            <td style="text-align: center; border-bottom: none !important; border-top: none !important;">{{ item.hsn }}</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format(item.qty|float) }}</td>
                            <td style="text-align: left; border-bottom: none !important; border-top: none !important;">{{ item.pack }}</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format(item.rate|float) }}</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format((item.tax_rate|float / 2)) }} %</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format((item.tax_amount|float / 2)|round(2)) }}</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format((item.tax_rate|float / 2)) }} %</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format((item.tax_amount|float / 2)|round(2)) }}</td>
                            <td style="text-align: right; border-bottom: none !important; border-top: none !important;">{{ "{:,.2f}".format(item.amount|float) }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- EMPTY SPACE SECTION ---------------- #}
    {% macro fill_space(height=0, text=' ') %}
    <table class="items-table" style="width: 190mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-left: 1px solid #000000 !important;
            border-right: 1px solid #000000 !important;
            border-bottom: none !important;
            border-top: none !important;
            text-align: center !important;
            flex-grow: 1; border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <tr style="border: none !important;">
            <td style="width: 4%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 25%; border-top: none !important; border-bottom: none !important; vertical-align: middle;">
                <div style="font-size: 9.5px; color: #555;">{{ text }}</div>
            </td>
            <td style="width: 8%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 9%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 6%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 6%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 7%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 6%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 7%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 6%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 7%; border-top: none !important; border-bottom: none !important;"></td>
            <td style="width: 9%; border-top: none !important; border-bottom: none !important;"></td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- TOTALS SECTION ---------------- #}
    {% macro totals_section(taxes, last_page=False) %}
    <table style="width: 190mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-left: 1px solid #000000 !important;
            border-right: 1px solid #000000 !important;
            border-collapse: collapse !important;
            background-color: #ffffff;" cellpadding="0" cellspacing="0">
        {% if last_page %}
        <tr>
            <td style="padding: 0;">
                <table class="items-table" style="width: 100% !important; border-collapse: collapse !important;" cellpadding="3" cellspacing="0">
                    <tr style="font-size: 9px; border-top: 1px solid #000000 !important; border-bottom: 1px solid #000000 !important;">
                        <td colspan="4" style="text-align: right; border-right: none !important; width: 46%;">Grand Total</td>
                        <td style="text-align: right; border-left: none !important; font-weight: normal; width: 6%;">
                            {% set q_sum = invoice["items"] | sum(attribute='qty') %}
                            {{ "{:,.2f}".format(q_sum|float) }} 
                        </td>
                        <td style="text-align: left; border-right: 1px solid #000000 !important; border-left: none !important; width: 6%;">
                            {% if invoice["items"]|length > 0 %}{{ invoice["items"][0].pack }}{% endif %}
                        </td>
                        <td colspan="5" style="border-right: 1px solid #000000 !important; width: 33%;"></td>
                        <td style="text-align: right; width: 9%;">
                            {% set amt_sum = invoice["items"] | sum(attribute='amount') %}
                            {{ "{:,.2f}".format(amt_sum|float) }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        {% else %}
        <tr>
            <td style="padding: 0; border-top: 1px solid #000000 !important;"></td>
        </tr>
        {% endif %}
        <tr>
            <td class="totals-section" style="padding: 2mm 2mm 4mm 2mm !important;">
                <table style="width: 100% !important; font-size: 9px;" cellpadding="0" cellspacing="0">
                    <tr>
                        <!-- Tax Summary Table -->
                        <td style="vertical-align: top !important; width: 50% !important; padding-right: 2mm;">
                            <table style="width: 100% !important; border-collapse: collapse !important; text-align: right;" cellpadding="2" cellspacing="0">
                                <thead>
                                    <tr>
                                        <th style="text-align: left; border-bottom: 1px solid #000000 !important; padding-bottom: 1mm; font-weight: normal;">Tax Rate</th>
                                        <th style="text-align: right; border-bottom: 1px solid #000000 !important; padding-bottom: 1mm; font-weight: normal;">Taxable Amt.</th>
                                        <th style="text-align: right; border-bottom: 1px solid #000000 !important; padding-bottom: 1mm; font-weight: normal;">CGST Amt.</th>
                                        <th style="text-align: right; border-bottom: 1px solid #000000 !important; padding-bottom: 1mm; font-weight: normal;">SGST Amt.</th>
                                        <th style="text-align: right; border-bottom: 1px solid #000000 !important; padding-bottom: 1mm; font-weight: normal;">Total Tax</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for tax in taxes %}
                                    {% set rate_num = tax.entity | replace('%','') | float %}
                                    <tr>
                                        <td style="text-align: left; border: none !important;">{{ tax.entity }}</td>
                                        <td style="text-align: right; border: none !important;">{{ "{:,.2f}".format(tax.taxable_value|float) }}</td>
                                        <td style="text-align: right; border: none !important;">{{ "{:,.2f}".format((tax.cgst or (tax.tax_amount / 2))|float) }}</td>
                                        <td style="text-align: right; border: none !important;">{{ "{:,.2f}".format((tax.sgst or (tax.tax_amount / 2))|float) }}</td>
                                        <td style="text-align: right; border: none !important;">{{ "{:,.2f}".format(tax.tax_amount|float) }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </td>
                        <td style="width: 50% !important;"></td>
                    </tr>
                </table>
                
                {% if last_page and invoice.total_in_words %}
                <div style="margin-top: 4mm; font-size: 11px; font-weight: normal;">
                    Rupees {{ invoice.total_in_words }}
                </div>
                {% endif %}
            </td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- FOOTERS SECTION ---------------- #}
    {% macro invoice_footer() %}
    <table style="width: 190mm !important;
            vertical-align: bottom !important;
            margin: 0mm auto !important;
            border: 1px solid #000000 !important;
            border-top: 1px solid #000000 !important;
            height: 60mm !important;
            flex-shrink: 0;
            page-break-inside: avoid;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="padding: 0 !important;">
                <table style="width: 100% !important; border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
                    <tr style="vertical-align: top;">
                        <!-- Terms & Conditions Column -->
                        <td style="width: 50% !important; border-right: 1px solid #000000; padding: 2mm !important;">
                            <div style="font-size: 8px; margin-bottom: 1mm;">Terms & Conditions</div>
                            <div style="font-size: 9px; line-height: 1.35; margin-bottom: 2mm;">
                                E.& O.E.<br>
                                1. Goods once sold will not be taken back or not exchanged..
                            </div>
                            <div style="font-size: 9px; line-height: 1.35; text-transform: uppercase;">
                                BANK DETAIL : {{ company.bank_name or 'UNION BANK OF INDIA' }}, ({{ company.bank_branch or 'BOB RAJSAMOND' }})<br>
                                A/C NO : &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{{ company.account_no or '592601010050729' }}, &nbsp;&nbsp;&nbsp;({{ company.account_no_2 or '16920200006528' }})<br>
                                IFSC: &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{{ company.ifsc or 'UBIN0559261' }} &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;({{ company.ifsc_2 or 'BARBOKANUDA' }})
                            </div>
                        </td>
                        <!-- Signatory Column -->
                        <td style="width: 50% !important; padding: 0 !important; text-align: left; vertical-align: top;">
                            <table style="width: 100%; height: 100%; border-collapse: collapse;" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="height: 25mm; vertical-align: top; padding: 2mm; font-size: 9px; border-bottom: 1px solid #000000;">
                                        Receiver's Signature &nbsp;&nbsp;&nbsp;:
                                    </td>
                                </tr>
                                <tr>
                                    <td style="vertical-align: top; padding: 2mm; text-align: right; height: 35mm;">
                                        <div style="height: 31mm; display: flex; flex-direction: column; justify-content: space-between;">
                                            <div style="font-size: 11px;">For {{ company.company_name }}</div>
                                            <div style="font-size: 10px;">Authorised Signatory</div>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- PAGE LOGIC ---------------- #}
    {% set total_items = invoice["items"]|length %}
    {% set total_hsn = invoice["taxes"]|length %}
    
    {# Configure row heights dynamically for motors template specifically #}
    {% set row_height = 6 %} {# Reduced from 10 to reflect unpadded rows #}
    {% set hsn_row_height = 5 %} 
    {% set items_header_height = 12 %} 
    {% set totals_base_height = 20 %} {# Motors has T&C in footer, so totals is just Grand Total + Tax headers #}
    {% set page_body_height = 150 %} {# Increased body available since header/footer are predictable #}
    
    {% set items_per_page = ((page_body_height - items_header_height) // row_height) | int %}
    {% set hsn_per_page = ((page_body_height - totals_base_height) // hsn_row_height) | int %}
    
    {% set items_pages = (total_items // items_per_page) + (1 if total_items % items_per_page > 0 else 0) %}
    {% if items_pages == 0 %}{% set items_pages = 1 %}{% endif %}
    
    {% set taxes_total_height = totals_base_height + (total_hsn * hsn_row_height) %}
    
    {% for page in range(items_pages) %}
        <div style="min-height: 275mm; display: flex; flex-direction: column; background-color: #ffffff; page-break-after: always; page-break-inside: avoid; box-sizing: border-box;">
        {% set start = page * items_per_page %}
        {% set end = start + items_per_page %}
        {% set page_items = invoice["items"][start:end] %}
        
        {{ invoice_header() }}
        {{ items_table(page_items, offset=start) }}
        
        {% if loop.last %}
            {% set space_used_by_items = items_header_height + (page_items|length * row_height) %}
            {% set remaining_space = page_body_height - space_used_by_items %}
            
            {% if remaining_space >= taxes_total_height %}
                {{ fill_space(remaining_space - taxes_total_height) }}
                {{ totals_section(invoice["taxes"], last_page=True) }}
                {{ invoice_footer() }}
                </div>
            {% else %}
                {{ fill_space(remaining_space, text='Continued on next page...') }}
                {{ invoice_footer() }}
                </div>
                
                {% set hsn_pages = (total_hsn // hsn_per_page) + (1 if total_hsn % hsn_per_page > 0 else 0) %}
                {% if hsn_pages == 0 %}{% set hsn_pages = 1 %}{% endif %}
                
                {% for p in range(hsn_pages) %}
                    <div style="min-height: 275mm; display: flex; flex-direction: column; background-color: #ffffff; page-break-after: always; page-break-inside: avoid; box-sizing: border-box;">
                    {{ invoice_header() }}
                    {% set hstart = p * hsn_per_page %}
                    {% set hend = hstart + hsn_per_page %}
                    {% set hsn_chunk = invoice["taxes"][hstart:hend] %}
                    
                    {{ fill_space(text='') }}
                    {{ totals_section(hsn_chunk, last_page=loop.last) }}
                    {{ invoice_footer() }}
                    </div>
                {% endfor %}
            {% endif %}
            
        {% else %}
            {% set space_used_by_items = items_header_height + (page_items|length * row_height) %}
            {{ fill_space(page_body_height - space_used_by_items, text='Continued on next page...') }}
            {{ invoice_footer() }}
            </div>
        {% endif %}
    {% endfor %}

    </div>
</body>
</html>
