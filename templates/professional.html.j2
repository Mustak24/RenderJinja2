<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Themeable Purple Invoice - Vyapar Drishti</title>
    <!-- Outfit Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* CSS Variables to control theme colors and styles */
        :root {
            --theme-primary: #5f33e1; /* The purple color in the image */
            --theme-text: #1f2937;
            --theme-text-light: #4b5563;
            --theme-border: #d1d5db;
            --theme-bg-light: #f9fafb;
            --theme-font: 'Outfit', sans-serif;
        }

        * {
            box-sizing: border-box !important;
        }

        body {
            padding: 0 !important;
            margin: 0 !important;
            font-family: var(--theme-font) !important;
            font-size: 10.5px;
            color: var(--theme-text);
            background-color: #ffffff;
        }

        @media print {
            body {
                margin: 0 !important;
                padding: 0 !important;
            }

            .no-print {
                display: none !important;
            }
        }

        .invoice-container {
            width: 190mm !important;
            margin: 0mm auto !important;
            background-color: #ffffff;
        }

        table.items-table {
            width: 100% !important;
            border-collapse: collapse !important;
            font-size: 9.5px !important;
            page-break-inside: auto;
            margin-top: 1mm;
        }

        .items-table tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        .items-table th {
            background-color: var(--theme-primary) !important;
            color: #ffffff !important;
            font-weight: 600 !important;
            font-size: 9.5px;
            border: 1px solid var(--theme-primary) !important;
            padding: 5px 4px !important;
        }

        .items-table td {
            border: 1px solid var(--theme-border) !important;
            padding: 5px 4px !important;
            color: var(--theme-text);
        }

        .items-table tr.total-row td {
            border-top: 1.5px solid var(--theme-primary) !important;
            border-bottom: 1.5px solid var(--theme-primary) !important;
            background-color: #ffffff !important;
        }

        .totals-section {
            page-break-inside: avoid;
            margin-top: 4mm;
        }
    </style>
</head>

<body style="display: flex; justify-content: center; margin: 0; padding: 0;">
    <div style="width: 190mm;">
    <div class="invoice-container">
    {# ---------------- HEADER SECTION ---------------- #}
    {% macro invoice_header() %}
    <table style="width: 190mm !important;
            height: 85mm !important; flex-shrink: 0;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <!-- Top Row with Company Details and Logo -->
        <tr>
            <td>
                <table style="width: 100% !important; border-collapse: collapse;" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="vertical-align: top; text-align: left;">
                            <div style="font-size: 18px; font-weight: 700; color: #000; margin-bottom: 1mm;">
                                {{ company.company_name | upper }}
                            </div>
                            <div style="font-size: 10px; color: var(--theme-text-light); line-height: 1.4;">
                                {{ company.address_1 }} , {{ company.address_2 }}<br>
                                State: {{ company.state }}{% if company.state_code %} (Code: {{ company.state_code }}){% endif %}<br>
                                {% if company.cin %}CIN: {{ company.cin }}<br>{% endif %}
                                {% if company.udyam %}UDYAM: {{ company.udyam }}<br>{% endif %}
                                Phone No: {{ company.phone.code }} {{ company.phone.number }}<br>
                                Email: {{ company.email }}<br>
                                GSTIN: {{ company.tin }}
                            </div>
                        </td>
                        <td style="width: 30mm; text-align: right; vertical-align: top;">
                            <div style="font-size: 9px; color: var(--theme-text-light); font-weight: 600; margin-bottom: 2mm; text-transform: uppercase; letter-spacing: 0.5px;">
                                ORIGINAL FOR RECIPIENT
                            </div>
                            <div style="width: 28mm; height: 20mm; display: inline-flex; align-items: center; justify-content: center;">
                                {% if company.logo_url %}
                                    <img src="{{ company.logo_url }}" style="max-width: 28mm; max-height: 20mm; object-fit: cover;" alt="Logo">
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- Thick Purple Divider Bar -->
        <tr>
            <td style="padding-top: 3mm;">
                <div style="border-top: 2.5px solid var(--theme-primary); width: 100%;"></div>
            </td>
        </tr>
        <!-- Centered Tax Invoice Title -->
        <tr>
            <td style="text-align: center; padding: 2.5mm 0 1mm 0;">
                <div style="font-size: 15px; font-weight: 700; color: var(--theme-primary); letter-spacing: 1.5px;">
                    TAX INVOICE
                </div>
            </td>
        </tr>
        <!-- Four-Column Metadata Grid -->
        <tr>
            <td style="padding-top: 1mm; padding-bottom: 2mm;">
                <table style="width: 100%; border-collapse: collapse; border-top: 1px solid var(--theme-border); border-bottom: 1px solid var(--theme-border);" cellpadding="5" cellspacing="0">
                    <tr>
                        <td style="width: 25%; vertical-align: top; padding-right: 2mm;">
                            <div style="font-weight: 700; font-size: 9px; color: #000; margin-bottom: 1mm; text-transform: uppercase;">BILL TO</div>
                            <div style="font-weight: 700; font-size: 10.5px; color: #000; margin-bottom: 0.5mm;">{{ party.name }}</div>
                            <div style="font-size: 9.5px; color: var(--theme-text-light); line-height: 1.35;">
                                {{ party.mailing_address }}<br>
                                {{ party.mailing_state }} - {{ party.mailing_pincode }} {{ party.mailing_country }}<br>
                                GSTIN: {{ party.tin }}
                            </div>
                        </td>
                        <td style="width: 25%; vertical-align: top; padding-right: 2mm; padding-left: 2mm; border-left: 1px solid var(--theme-border);">
                            <div style="font-weight: 700; font-size: 9px; color: #000; margin-bottom: 1mm; text-transform: uppercase;">SHIP TO</div>
                            <div style="font-weight: 700; font-size: 10.5px; color: #000; margin-bottom: 0.5mm;">{{ party.name }}</div>
                            <div style="font-size: 9.5px; color: var(--theme-text-light); line-height: 1.35;">
                                {{ party.mailing_address }}<br>
                                {{ party.mailing_state }} - {{ party.mailing_pincode }} {{ party.mailing_country }}
                            </div>
                        </td>
                        <td style="width: 25%; vertical-align: top; padding-right: 2mm; padding-left: 2mm; border-left: 1px solid var(--theme-border);">
                            <div style="font-weight: 700; font-size: 9px; color: #000; margin-bottom: 1.5mm; text-transform: uppercase;">TRANSPORTATION DETAILS</div>
                            <div style="font-size: 9.5px; color: var(--theme-text-light); line-height: 1.45;">
                                Transport Mode: {{ invoice.mode_of_transport }}<br>
                                Vehicle No: {{ invoice.vehicle_number }}
                            </div>
                        </td>
                        <td style="width: 25%; vertical-align: top; padding-left: 2mm; border-left: 1px solid var(--theme-border);">
                            <div style="font-weight: 700; font-size: 9px; color: #000; margin-bottom: 1.5mm; text-transform: uppercase;">INVOICE DETAILS</div>
                            <div style="font-size: 9.5px; color: var(--theme-text-light); line-height: 1.45;">
                                Invoice No: {{ invoice.voucher_number }}<br>
                                Date: {{ invoice.date }}<br>
                                Place of Supply: {{ invoice.place_of_supply }}
                            </div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}



    {# ---------------- ITEMS TABLE ---------------- #}
    {% macro items_table(items, offset=0) %}
    <table style="width: 190mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <tr>
            <td style="padding: 0mm !important;">
                <table class="items-table" cellpadding="5" cellspacing="0">
                    <thead>
                        <tr>
                            <th style="width: 5%; text-align: center;">S.No</th>
                            <th style="width: 33%; text-align: left;">Item Name</th>
                            <th style="width: 12%; text-align: center;">HSN/SAC</th>
                            <th style="width: 8%; text-align: center;">Quantity</th>
                            <th style="width: 7%; text-align: center;">Unit</th>
                            <th style="width: 9%; text-align: right;">Rate</th>
                            <th style="width: 7%; text-align: right;">Dis.</th>
                            <th style="width: 10%; text-align: right;">Taxable Amt</th>
                            <th style="width: 9%; text-align: right;">GST</th>
                            <th style="width: 10%; text-align: right; padding-right: 4px !important;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in items %}
                        <tr>
                            <td style="text-align: center;">{{ offset + loop.index }}</td>
                            <td style="text-align: left; font-weight: 500;">{{ item.name }}</td>
                            <td style="text-align: center; font-family: monospace;">{{ item.hsn }}</td>
                            <td style="text-align: center;">{{ item.qty }}</td>
                            <td style="text-align: center; font-size: 8.5px;">{{ item.pack }}</td>
                            <td style="text-align: right;">{{ item.rate|float|round(2) }}</td>
                            <td style="text-align: right;">{{ item.discount_amount|float|round(2) }}</td>
                            <td style="text-align: right;">{{ item.tax_amount|float|round(2) }}</td>
                            <td style="text-align: right;">
                                {% if loop.index0 < invoice.taxes|length %}
                                    {{ invoice.taxes[loop.index0].tax_amount|float|round(2) }}
                                {% else %}
                                    0.00
                                {% endif %}
                            </td>
                            <td style="text-align: right; font-weight: bold; padding-right: 4px !important;">{{ item.total_amount|float|round(2) }}</td>
                        </tr>
                        {% endfor %}
                        
                        <!-- Totals Summary Row -->
                        <tr class="total-row">
                            <td></td>
                            <td style="font-weight: bold;">Total:</td>
                            <td></td>
                            <td style="text-align: center; font-weight: bold;">
                                {{ items|sum(attribute='qty') }}
                            </td>
                            <td></td>
                            <td></td>
                            <td></td>
                            <td style="text-align: right; font-weight: bold;">
                                {{ items|sum(attribute='tax_amount')|float|round(2) }}
                            </td>
                            <td style="text-align: right; font-weight: bold;">
                                {% set gst_sum = namespace(val=0.0) %}
                                {% for item in items %}
                                    {% if loop.index0 < invoice.taxes|length %}
                                        {% set gst_sum.val = gst_sum.val + invoice.taxes[loop.index0].tax_amount|float %}
                                    {% endif %}
                                {% endfor %}
                                {{ gst_sum.val|float|round(2) }}
                            </td>
                            <td style="text-align: right; font-weight: bold; padding-right: 4px !important;">
                                {{ items|sum(attribute='total_amount')|float|round(2) }}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- TOTALS SECTION ---------------- #}
    {% macro totals_section(taxes, last_page=False) %}
    <table style="width: 190mm !important;
            min-height: 40mm !important;
            vertical-align: top !important;
            margin: 0mm auto !important;
            border-collapse: collapse !important;
            background-color: #ffffff;" cellpadding="0" cellspacing="0">
        <tr>
            <td class="totals-section" style="padding: 4mm 0 !important;">
                <table style="width: 100% !important;" cellpadding="0" cellspacing="0">
                    <tr>
                        <!-- Terms and Conditions List -->
                        <td style="vertical-align: top !important; width: 110mm !important; padding-right: 4mm;">
                            <div style="font-weight: bold; font-size: 10.5px; margin-bottom: 2mm;">Terms and Conditions:</div>
                            <ol style="margin: 0; padding-left: 4mm; font-size: 9.5px; color: var(--theme-text-light); line-height: 1.45;">
                                <li>This is to certify that we have a valid GST Registration and the above information is true.</li>
                                <li>Interest @ 18% per annum will be charged on payments due after 15 days from the date of billing.</li>
                                <li>Please accept goods in proper condition only.</li>
                                <li>All Disputes & claims will be referred to the court at Udaipur jurisdiction.</li>
                                <li>Do not make payment without the printed receipt. Please keep the receipt safe.</li>
                            </ol>
                        </td>

                        <!-- Invoice Totals breakdown box -->
                        {% if last_page %}
                        <td style="vertical-align: top !important; padding-left: 2mm !important;">
                            <div style="page-break-inside: avoid;">
                                <table style="width: 78mm !important; font-size: 9.5px !important; border-collapse: collapse; border: 1.5px solid var(--theme-primary); border-radius: 4px; overflow: hidden;" cellpadding="5.5" cellspacing="0">
                                    <tr style="border-bottom: 1px solid var(--theme-border);">
                                        <td style="color: var(--theme-text-light); font-weight: 500;">Sub Total</td>
                                        <td class="text-right bold" style="color: var(--theme-text);">
                                            {{ invoice["items"]|sum(attribute='tax_amount')|float|round(2) }}
                                        </td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid var(--theme-border);">
                                        <td style="color: var(--theme-text-light); font-weight: 500;">CGST@N/A%</td>
                                        <td class="text-right bold" style="color: var(--theme-text);">
                                            {{ invoice.totals.cgst|float|round(2) }}
                                        </td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid var(--theme-border);">
                                        <td style="color: var(--theme-text-light); font-weight: 500;">SGST@N/A%</td>
                                        <td class="text-right bold" style="color: var(--theme-text);">
                                            {{ invoice.totals.sgst|float|round(2) }}
                                        </td>
                                    </tr>
                                    <tr style="border-bottom: 1px solid var(--theme-border);">
                                        <td style="color: var(--theme-text-light); font-weight: 500;">Round Off</td>
                                        <td class="text-right bold" style="color: var(--theme-text);">
                                            {{ invoice.roundoff|float|round(2) }}
                                        </td>
                                    </tr>
                                    <tr style="background-color: var(--theme-primary) !important; color: #ffffff !important;">
                                        <td class="bold" style="font-size: 11px; padding: 7px 5px !important;">Grand Total</td>
                                        <td class="text-right bold" style="font-size: 12px; padding: 7px 5px !important;">
                                            ₹ {{ invoice.grand_total|float|round(2) }}
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </td>
                        {% endif %}
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    {% endmacro %}


    {# ---------------- FOOTERS SECTION ---------------- #}
    {% macro invoice_footer() %}
    <table style="width: 190mm !important;
            height: 60mm !important; flex-shrink: 0;
            vertical-align: bottom !important;
            margin: 0mm auto !important;
            border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
        <!-- Signatures & Payment / QR Section -->
        <tr>
            <td style="padding: 4mm 0 !important;">
                <table style="width: 100% !important; border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
                    <tr>
                        <!-- QR Code & Bank Info -->
                        <td style="width: 60% !important; vertical-align: middle;">
                            <table style="border-collapse: collapse;" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td style="width: 24mm; height: 24mm; text-align: center; vertical-align: middle;">
                                        {% if company.qr_code_url %}
                                            <img src="{{ company.qr_code_url }}" style="max-width: 24mm; max-height: 24mm; object-fit: cover;" alt="Logo">
                                        {% endif %}
                                    </td>
                                    <td style="padding-left: 4mm; vertical-align: middle; line-height: 1.45; font-size: 9.5px; color: var(--theme-text-light);">
                                        <strong style="font-size: 10.5px; color: #000; display: block; margin-bottom: 0.5mm;">Pay To:</strong>
                                        Bank Name: {{ company.bank_name }}<br>
                                        {{ company.bank_branch }}<br>
                                        A/C No: {{ company.account_no }}<br>
                                        IFS Code: {{ company.ifsc }}
                                    </td>
                                </tr>
                            </table>
                        </td>
                        
                        <!-- Signature Area -->
                        <td style="width: 40% !important; text-align: right !important; vertical-align: top !important; padding-right: 2mm;">
                            <div style="font-weight: 700; font-size: 10.5px; color: #000; margin-bottom: 12mm;">
                                For {{ company.company_name }}
                            </div>
                            <div style="font-size: 10px; color: var(--theme-text-light); font-weight: 500;">
                                Authorised Signatory
                            </div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        <!-- Centered Motto and Tagline -->
        <tr>
            <td style="text-align: center !important; padding-top: 4mm !important;">
                <div style="font-size: 11px !important; font-weight: 700 !important; color: var(--theme-primary); letter-spacing: 0.5px; margin-bottom: 0.5mm; text-transform: uppercase;">
                    {{ company.motto or "LIFE'S A JOURNEY, KEEP SMILING" }}
                </div>
                <div style="font-size: 8px !important; color: var(--theme-text-light);">
                    This Purchase Invoice generated by Vyapar Drishti GST Billing App.
                </div>
            </td>
        </tr>
    </table>
    {% endmacro %}

    {# ---------------- EMPTY SPACE SECTION ---------------- #}
    {% macro fill_space(height=0, text=' ') %}
    <div style="flex-grow: 1; display: flex; flex-direction: column; width: 190mm !important; margin: 0 auto !important;">
        <table style="width: 100% !important;
                height: 100% !important;
                vertical-align: top !important;
                margin: 0 !important;
                text-align: center !important;
                border-collapse: collapse !important;" cellpadding="0" cellspacing="0">
            <tr>
                <td style=" border: none; font-size: 9.5px; color: var(--theme-text-light); font-style: italic; vertical-align: middle;">{{ text }}</td>
            </tr>
        </table>
    </div>
    {% endmacro %}


    {# ---------------- PAGE LOGIC ---------------- #}
    {% set total_items = invoice["items"]|length %}
    {% set total_hsn = invoice["taxes"]|length %}
    
    {# Configure row heights dynamically. Modify these if template padding changes. #}
    {% set row_height = 6 %} {# increased for safety #}
    {% set hsn_row_height = 6 %} 
    {% set items_header_height = 12 %} 
    {% set totals_base_height = 45 %} 
    {% set page_body_height = 135 %} {# smaller to leave margin for overflow #}
    
    {% set items_per_page = ((page_body_height - items_header_height) // row_height) | int %}
    {% set hsn_per_page = ((page_body_height - totals_base_height) // hsn_row_height) | int %}
    
    {% set items_pages = (total_items // items_per_page) + (1 if total_items % items_per_page > 0 else 0) %}
    {% if items_pages == 0 %}{% set items_pages = 1 %}{% endif %}
    
    {% set taxes_total_height = totals_base_height + (total_hsn * hsn_row_height) %}
    
    {% for page in range(items_pages) %}
        <div style="min-height: 275mm; display: flex; flex-direction: column; background-color: #ffffff; page-break-after: always; page-break-inside: avoid; box-sizing: border-box;">
        {% set start = page * items_per_page %}
        {% set end = start + items_per_page %}
        {% set page_items = invoice["items"][start:end] %}
        
        {{ invoice_header() }}
        {{ items_table(page_items, offset=start) }}
        
        {% if loop.last %}
            {% set space_used_by_items = items_header_height + (page_items|length * row_height) %}
            {% set remaining_space = page_body_height - space_used_by_items %}
            
            {% if remaining_space >= taxes_total_height %}
                {{ fill_space(remaining_space - taxes_total_height) }}
                {{ totals_section(invoice["taxes"], last_page=True) }}
                {{ invoice_footer() }}
                </div>
            {% else %}
                {{ fill_space(remaining_space, text='Continued on next page...') }}
                {{ invoice_footer() }}
                </div>
                
                {% set hsn_pages = (total_hsn // hsn_per_page) + (1 if total_hsn % hsn_per_page > 0 else 0) %}
                {% if hsn_pages == 0 %}{% set hsn_pages = 1 %}{% endif %}
                
                {% for p in range(hsn_pages) %}
                    <div style="min-height: 275mm; display: flex; flex-direction: column; background-color: #ffffff; page-break-after: always; page-break-inside: avoid; box-sizing: border-box;">
                    {{ invoice_header() }}
                    {% set hstart = p * hsn_per_page %}
                    {% set hend = hstart + hsn_per_page %}
                    {% set hsn_chunk = invoice["taxes"][hstart:hend] %}
                    
                    {{ fill_space(text='') }}
                    {{ totals_section(hsn_chunk, last_page=loop.last) }}
                    {{ invoice_footer() }}
                    </div>
                {% endfor %}
            {% endif %}
            
        {% else %}
            {% set space_used_by_items = items_header_height + (page_items|length * row_height) %}
            {{ fill_space(page_body_height - space_used_by_items, text='Continued on next page...') }}
            {{ invoice_footer() }}
            </div>
        {% endif %}
    {% endfor %}

    </div>
    </div>
</body>
</html>
